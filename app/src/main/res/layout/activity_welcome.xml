<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/welcomeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Background Decoration -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="-100dp"
        android:layout_marginEnd="-100dp"
        android:background="@drawable/bg_circle"
        android:backgroundTint="#F0F7FF" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Book Icon Illustration -->
        <ImageView
            android:id="@+id/logo"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:src="@drawable/book"
            android:scaleType="fitCenter"
            android:layout_marginBottom="32dp"/>

        <!-- App Name / Title -->
        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HITC Bookstore"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:layout_marginBottom="12dp"/>

        <!-- Slogan / Subtitle -->
        <TextView
            android:id="@+id/txtSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mở cửa tâm hồn, khám phá tri thức mới qua từng trang sách"
            android:textSize="16sp"
            android:textColor="#546E7A"
            android:gravity="center"
            android:lineSpacingExtra="4dp"/>

    </LinearLayout>

    <!-- Continue Button - Raised higher -->
    <Button
        android:id="@+id/objNext"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Khám phá ngay"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:backgroundTint="#2196F3"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="100dp"
        android:layout_marginHorizontal="40dp"
        app:cornerRadius="30dp"
        android:elevation="8dp"/>

</RelativeLayout>
